PORT=3000
NODE_ENV=development
# Set MONGO_URI to use a real MongoDB instance.
# If left unset and USE_MEMORY_DB=true, the app will spin up an in-memory MongoDB
# so you can evaluate the app without installing MongoDB.
MONGO_URI=mongodb://127.0.0.1:27017/mypos
USE_MEMORY_DB=false
SESSION_SECRET=change-me-in-production
