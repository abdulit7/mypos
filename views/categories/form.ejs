<div class="max-w-xl">
  <h1 class="text-2xl font-bold mb-4"><%= title %></h1>
  <form method="POST" action="<%= category._id ? rurl('/categories/' + category._id) + '?_method=PUT' : rurl('/categories') %>" class="card space-y-3">
    <div>
      <label class="block text-sm font-medium mb-1">Name</label>
      <input name="name" value="<%= category.name || '' %>" class="input" required />
    </div>
    <div>
      <label class="block text-sm font-medium mb-1">Description</label>
      <textarea name="description" class="input" rows="3"><%= category.description || '' %></textarea>
    </div>
    <label class="inline-flex items-center gap-2">
      <input type="checkbox" name="active" <%= (category._id === undefined || category.active) ? 'checked' : '' %> />
      <span>Active</span>
    </label>
    <div class="flex gap-2">
      <button class="btn-primary">Save</button>
      <a href="<%= rurl('/categories') %>" class="btn-secondary">Cancel</a>
    </div>
  </form>
</div>
