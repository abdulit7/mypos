<% const isNew = !restaurant._id; %>
<h1 class="text-2xl font-bold mb-4"><%= isNew ? 'New Restaurant' : 'Edit Restaurant' %></h1>

<form method="POST" action="<%= isNew ? '/superadmin/restaurants' : '/superadmin/restaurants/' + restaurant._id + '?_method=PUT' %>" class="grid md:grid-cols-2 gap-4">
  <div class="bg-white rounded-lg shadow p-4 space-y-3">
    <h2 class="font-semibold">Restaurant details</h2>
    <div>
      <label class="block text-sm font-medium mb-1">Name</label>
      <input name="name" class="input" value="<%= restaurant.name || '' %>" required />
    </div>
    <div class="grid grid-cols-2 gap-3">
      <div>
        <label class="block text-sm font-medium mb-1">Owner name</label>
        <input name="ownerName" class="input" value="<%= restaurant.ownerName || '' %>" />
      </div>
      <div>
        <label class="block text-sm font-medium mb-1">Phone</label>
        <input name="phone" class="input" value="<%= restaurant.phone || '' %>" />
      </div>
    </div>
    <div>
      <label class="block text-sm font-medium mb-1">Address</label>
      <textarea name="address" rows="2" class="input"><%= restaurant.address || '' %></textarea>
    </div>
    <div class="grid grid-cols-2 gap-3">
      <div>
        <label class="block text-sm font-medium mb-1">Currency symbol</label>
        <input name="currency" class="input" value="<%= restaurant.currency || 'Rs' %>" />
      </div>
      <div>
        <label class="block text-sm font-medium mb-1">Default tax %</label>
        <input name="taxRate" type="number" step="0.01" class="input" value="<%= restaurant.taxRate || 0 %>" />
      </div>
    </div>
  </div>

  <div class="bg-white rounded-lg shadow p-4 space-y-3">
    <h2 class="font-semibold">Subscription</h2>
    <div class="grid grid-cols-2 gap-3">
      <div>
        <label class="block text-sm font-medium mb-1">Max users</label>
        <input name="maxUsers" type="number" min="1" class="input" value="<%= restaurant.maxUsers || 5 %>" />
      </div>
      <div>
        <label class="block text-sm font-medium mb-1">Expires on</label>
        <input name="expiresAt" type="date" class="input" value="<%= restaurant.expiresAt ? new Date(restaurant.expiresAt).toISOString().slice(0,10) : '' %>" />
      </div>
    </div>
    <label class="inline-flex items-center gap-2 text-sm">
      <input type="checkbox" name="isActive" <%= restaurant.isActive !== false ? 'checked' : '' %> />
      <span>Active</span>
    </label>

    <% if (isNew) { %>
      <hr />
      <h2 class="font-semibold">Restaurant admin user</h2>
      <p class="text-xs text-slate-500">This user will sign in to manage the restaurant and create cashiers.</p>
      <div>
        <label class="block text-sm font-medium mb-1">Full name</label>
        <input name="adminName" class="input" value="<%= adminDefaults?.name || '' %>" />
      </div>
      <div class="grid grid-cols-2 gap-3">
        <div>
          <label class="block text-sm font-medium mb-1">Username</label>
          <input name="adminUsername" class="input" value="<%= adminDefaults?.username || '' %>" required />
        </div>
        <div>
          <label class="block text-sm font-medium mb-1">Password</label>
          <input name="adminPassword" type="password" class="input" required />
        </div>
      </div>
    <% } %>
  </div>

  <div class="md:col-span-2 flex items-center gap-3">
    <button class="btn-primary"><%= isNew ? 'Create Restaurant' : 'Save Changes' %></button>
    <a href="/superadmin/restaurants" class="text-sm text-slate-600 hover:underline">Cancel</a>
  </div>
</form>
