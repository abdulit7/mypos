<div class="flex items-center justify-between mb-6">
  <h1 class="text-2xl font-bold">Super Admin Overview</h1>
  <a href="/admin/restaurants/new" class="btn-primary">+ New Restaurant</a>
</div>

<div class="grid grid-cols-2 md:grid-cols-5 gap-3 mb-6">
  <div class="bg-white rounded-lg shadow p-4">
    <div class="text-xs uppercase text-slate-500">Restaurants</div>
    <div class="text-2xl font-bold"><%= stats.restaurantCount %></div>
  </div>
  <div class="bg-white rounded-lg shadow p-4">
    <div class="text-xs uppercase text-slate-500">Active</div>
    <div class="text-2xl font-bold text-emerald-600"><%= stats.activeCount %></div>
  </div>
  <div class="bg-white rounded-lg shadow p-4">
    <div class="text-xs uppercase text-slate-500">Expired</div>
    <div class="text-2xl font-bold text-amber-600"><%= stats.expiredCount %></div>
  </div>
  <div class="bg-white rounded-lg shadow p-4">
    <div class="text-xs uppercase text-slate-500">Users</div>
    <div class="text-2xl font-bold"><%= stats.userCount %></div>
  </div>
  <div class="bg-white rounded-lg shadow p-4">
    <div class="text-xs uppercase text-slate-500">Total Orders</div>
    <div class="text-2xl font-bold"><%= stats.orderCount %></div>
  </div>
</div>

<div class="bg-white rounded-lg shadow overflow-hidden">
  <div class="px-4 py-3 border-b font-semibold">Recent Restaurants</div>
  <% if (!recent.length) { %>
    <div class="p-6 text-sm text-slate-500">No restaurants yet. Click "+ New Restaurant" to add one.</div>
  <% } else { %>
    <table class="w-full text-sm">
      <thead class="text-left text-slate-500 bg-slate-50">
        <tr><th class="px-4 py-2">Name</th><th class="px-4 py-2">Owner</th><th class="px-4 py-2">Expires</th><th class="px-4 py-2">Status</th></tr>
      </thead>
      <tbody>
        <% recent.forEach(function(r){ %>
          <tr class="border-t">
            <td class="px-4 py-2"><a class="text-brand-600 hover:underline" href="/admin/restaurants/<%= r._id %>"><%= r.name %></a></td>
            <td class="px-4 py-2"><%= r.ownerName || '—' %></td>
            <td class="px-4 py-2"><%= r.expiresAt ? new Date(r.expiresAt).toISOString().slice(0,10) : '—' %></td>
            <td class="px-4 py-2"><%= r.isActive ? 'Active' : 'Suspended' %></td>
          </tr>
        <% }); %>
      </tbody>
    </table>
  <% } %>
</div>
