<!doctype html>
<html lang="en">
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width,initial-scale=1" />
  <title><%= title ? title + ' · ' : '' %><%= appName %></title>
  <link rel="stylesheet" href="/css/tailwind.css" />
  <link rel="icon" href="data:image/svg+xml,<svg xmlns='http://www.w3.org/2000/svg' viewBox='0 0 64 64'><text y='54' font-size='56'>🍗</text></svg>" />
</head>
<body class="min-h-screen bg-gray-50 text-gray-900">
  <header class="bg-gradient-to-r from-brand-600 to-brand-700 text-white shadow">
    <div class="max-w-7xl mx-auto px-4 py-3 flex items-center gap-6">
      <a href="/" class="flex items-center gap-2 font-bold text-lg">
        <span>🍗</span><span><%= appName %></span>
      </a>
      <nav class="flex items-center gap-1 text-sm flex-wrap">
        <% const navItems = [
          { href: '/', label: 'Dashboard', perm: null },
          { href: '/pos', label: 'POS', perm: 'pos.access' },
          { href: '/orders', label: 'Orders', perm: 'orders.view' },
          { href: '/products', label: 'Products', perm: 'products.manage' },
          { href: '/categories', label: 'Categories', perm: 'categories.manage' },
          { href: '/reports', label: 'Reports', perm: 'reports.view' },
          { href: '/users', label: 'Users', perm: 'users.manage' },
        ]; %>
        <% navItems.forEach(function(item){
             if (item.perm && !hasPermission(item.perm)) return;
             const active = path === item.href || (item.href !== '/' && path.startsWith(item.href));
        %>
          <a href="<%= item.href %>" class="px-3 py-1.5 rounded-md <%= active ? 'bg-white/20' : 'hover:bg-white/10' %>"><%= item.label %></a>
        <% }); %>
      </nav>
      <div class="ml-auto flex items-center gap-3 text-sm">
        <% if (currentRestaurant) { %>
          <span class="hidden md:inline text-white/80"><%= currentRestaurant.name %></span>
        <% } %>
        <% if (currentUser) { %>
          <span>Hi, <strong><%= currentUser.name %></strong> (<%= currentUser.role %>)</span>
          <form action="/logout" method="POST">
            <button type="submit" class="bg-white/10 hover:bg-white/20 px-3 py-1.5 rounded-md">Sign out</button>
          </form>
        <% } %>
      </div>
    </div>
  </header>

  <main class="max-w-7xl mx-auto px-4 py-6">
    <% if (success && success.length) { %>
      <div class="mb-4 rounded-md bg-emerald-100 text-emerald-800 px-4 py-2"><%= success.join(' ') %></div>
    <% } %>
    <% if (error && error.length) { %>
      <div class="mb-4 rounded-md bg-red-100 text-red-800 px-4 py-2"><%= error.join(' ') %></div>
    <% } %>
    <%- body %>
  </main>

  <footer class="max-w-7xl mx-auto px-4 py-6 text-xs text-gray-500">
    &copy; <%= new Date().getFullYear() %> <%= appName %>
  </footer>
</body>
</html>
