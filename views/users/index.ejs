<div class="flex items-center justify-between mb-4">
  <div>
    <h1 class="text-2xl font-bold">Users</h1>
    <p class="text-sm text-gray-500"><%= users.length %> / <%= maxUsers %> users used</p>
  </div>
  <a href="/users/new" class="btn-primary" <%= users.length >= maxUsers ? 'aria-disabled="true" style="pointer-events:none;opacity:0.5"' : '' %>>+ New User</a>
</div>

<div class="bg-white rounded-lg shadow overflow-hidden">
  <table class="w-full text-sm">
    <thead class="text-left text-gray-500 bg-gray-50">
      <tr>
        <th class="px-4 py-2">Name</th>
        <th class="px-4 py-2">Username</th>
        <th class="px-4 py-2">Role</th>
        <th class="px-4 py-2">Permissions</th>
        <th class="px-4 py-2">Active</th>
        <th class="px-4 py-2 text-right"></th>
      </tr>
    </thead>
    <tbody>
      <% users.forEach(function(u){ %>
        <tr class="border-t">
          <td class="px-4 py-2 font-medium"><%= u.name %></td>
          <td class="px-4 py-2"><code><%= u.username %></code></td>
          <td class="px-4 py-2"><span class="inline-block px-2 py-0.5 rounded text-xs bg-slate-200 text-slate-700"><%= u.role %></span></td>
          <td class="px-4 py-2 text-xs text-slate-500">
            <% if (u.role === 'admin') { %>All (admin)<% } else if (!u.permissions || !u.permissions.length) { %>None<% } else { %><%= u.permissions.length %> set<% } %>
          </td>
          <td class="px-4 py-2"><%= u.active === false ? 'No' : 'Yes' %></td>
          <td class="px-4 py-2 text-right">
            <a href="/users/<%= u._id %>/edit" class="text-brand-600 hover:underline mr-2">Edit</a>
            <form method="POST" action="/users/<%= u._id %>?_method=DELETE" class="inline" onsubmit="return confirm('Delete this user?');">
              <button class="text-red-600 hover:underline" type="submit">Delete</button>
            </form>
          </td>
        </tr>
      <% }); %>
    </tbody>
  </table>
</div>
