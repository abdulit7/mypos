<div class="grid gap-4 lg:grid-cols-3">
  <div class="lg:col-span-2 card">
    <div class="flex flex-wrap items-center gap-2 mb-3">
      <h1 class="text-xl font-bold mr-auto">🧾 Point of Sale</h1>
      <input id="productSearch" class="input max-w-xs" placeholder="Search products (name / SKU)" />
    </div>

    <div id="categoryTabs" class="flex flex-wrap gap-2 mb-3">
      <button type="button" data-cat="all" class="cat-tab px-3 py-1.5 rounded-full bg-brand-600 text-white text-sm">All</button>
      <% categories.forEach(function(c){ %>
        <button type="button" data-cat="<%= c._id %>" class="cat-tab px-3 py-1.5 rounded-full bg-gray-200 text-gray-700 text-sm"><%= c.name %></button>
      <% }); %>
    </div>

    <div id="productGrid" class="grid grid-cols-2 sm:grid-cols-3 md:grid-cols-4 gap-3">
      <% products.forEach(function(p){ %>
        <button type="button"
                class="product-card text-left bg-white border rounded-lg p-3 hover:shadow-md hover:border-brand-500 transition"
                data-id="<%= p._id %>"
                data-name="<%= p.name %>"
                data-price="<%= p.price %>"
                data-sku="<%= p.sku || '' %>"
                data-cat="<%= p.category ? p.category._id : '' %>">
          <div class="flex items-center justify-center w-full h-20 rounded bg-gray-100 mb-2 overflow-hidden">
            <% if (p.image) { %>
              <img src="<%= p.image %>" class="object-cover w-full h-full" />
            <% } else { %>
              <span class="text-3xl">🍽️</span>
            <% } %>
          </div>
          <div class="font-semibold text-sm leading-tight"><%= p.name %></div>
          <div class="text-xs text-gray-500"><%= p.category ? p.category.name : '' %></div>
          <div class="text-brand-700 font-bold mt-1">Rs <%= p.price.toFixed(2) %></div>
        </button>
      <% }); %>
    </div>
  </div>

  <div class="card sticky top-4 self-start">
    <div class="flex items-center justify-between">
      <h2 class="text-lg font-bold">Current Order</h2>
      <button type="button" id="clearCart" class="text-xs text-red-600 hover:underline">Clear</button>
    </div>

    <div class="mt-2 grid grid-cols-2 gap-2 text-sm">
      <div>
        <label class="block text-xs text-gray-500">Order Type</label>
        <select id="orderType" class="input py-1 text-sm">
          <option value="dine-in">Dine-in</option>
          <option value="takeaway">Takeaway</option>
          <option value="delivery">Delivery</option>
        </select>
      </div>
      <div>
        <label class="block text-xs text-gray-500">Table #</label>
        <input id="tableNo" class="input py-1 text-sm" placeholder="e.g. 4" />
      </div>
      <div>
        <label class="block text-xs text-gray-500">Customer Name</label>
        <input id="customerName" class="input py-1 text-sm" />
      </div>
      <div>
        <label class="block text-xs text-gray-500">Phone</label>
        <input id="customerPhone" class="input py-1 text-sm" />
      </div>
    </div>

    <div class="mt-3 max-h-80 overflow-y-auto divide-y" id="cartList">
      <div class="text-sm text-gray-500 py-6 text-center" id="cartEmpty">Cart is empty. Tap items to add.</div>
    </div>

    <div class="mt-3 grid grid-cols-2 gap-2 text-sm">
      <div>
        <label class="block text-xs text-gray-500">Tax %</label>
        <input id="taxRate" type="number" min="0" step="0.01" value="0" class="input py-1 text-sm" />
      </div>
      <div>
        <label class="block text-xs text-gray-500">Discount (Rs)</label>
        <input id="discount" type="number" min="0" step="0.01" value="0" class="input py-1 text-sm" />
      </div>
      <div class="col-span-2">
        <label class="block text-xs text-gray-500">Note</label>
        <input id="note" class="input py-1 text-sm" placeholder="Optional notes" />
      </div>
    </div>

    <div class="mt-3 space-y-1 text-sm">
      <div class="flex justify-between"><span>Subtotal</span><span>Rs <span id="sumSubtotal">0.00</span></span></div>
      <div class="flex justify-between"><span>Tax</span><span>Rs <span id="sumTax">0.00</span></span></div>
      <div class="flex justify-between"><span>Discount</span><span>- Rs <span id="sumDiscount">0.00</span></span></div>
      <div class="flex justify-between text-base font-bold"><span>Total</span><span>Rs <span id="sumTotal">0.00</span></span></div>
    </div>

    <div class="mt-3 grid grid-cols-2 gap-2 text-sm">
      <div>
        <label class="block text-xs text-gray-500">Paid (Rs)</label>
        <input id="paid" type="number" min="0" step="0.01" class="input py-1 text-sm" />
      </div>
      <div>
        <label class="block text-xs text-gray-500">Change</label>
        <div id="changeVal" class="input py-1 text-sm bg-gray-50">Rs 0.00</div>
      </div>
      <div class="col-span-2">
        <label class="block text-xs text-gray-500">Payment Method</label>
        <select id="paymentMethod" class="input py-1 text-sm">
          <option value="cash">Cash</option>
          <option value="card">Card</option>
          <option value="online">Online</option>
        </select>
      </div>
    </div>

    <div class="mt-4 grid grid-cols-2 gap-2">
      <button id="holdBtn" class="btn-secondary">Hold</button>
      <button id="payBtn" class="btn-success">Pay &amp; Print</button>
    </div>

    <% if (heldOrders && heldOrders.length) { %>
      <div class="mt-4 pt-3 border-t">
        <div class="text-xs uppercase text-gray-500 mb-2">Held Orders</div>
        <div class="space-y-1 max-h-40 overflow-y-auto">
          <% heldOrders.forEach(function(h){ %>
            <div class="flex items-center justify-between text-sm">
              <div>
                <div class="font-mono"><%= h.invoiceNo %></div>
                <div class="text-xs text-gray-500"><%= h.items.length %> items · Rs <%= h.total.toFixed(2) %></div>
              </div>
              <div class="flex gap-2">
                <a href="/pos?load=<%= h._id %>" class="text-brand-700 hover:underline">Resume</a>
                <form method="POST" action="/orders/<%= h._id %>?_method=DELETE" onsubmit="return confirm('Remove held order?');">
                  <button class="text-red-600 hover:underline">✕</button>
                </form>
              </div>
            </div>
          <% }); %>
        </div>
      </div>
    <% } %>
  </div>
</div>

<script>
  window.__POS__ = {
    loadedHeld: <%- JSON.stringify(loadedHeld || null) %>,
  };
</script>
<script src="/js/pos.js"></script>
