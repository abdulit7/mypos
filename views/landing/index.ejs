<div class="min-h-screen"
     style="background: radial-gradient(1200px 600px at 10% 0%, #16a34a22, transparent 60%), radial-gradient(1200px 600px at 90% 100%, #0d948822, transparent 60%), #0f172a;">
  <div class="max-w-5xl mx-auto px-4 py-12 text-white">
    <div class="flex items-center gap-3 mb-10">
      <span class="w-12 h-12 rounded-xl flex items-center justify-center text-2xl shadow-lg"
            style="background: linear-gradient(135deg, #22c55e, #0d9488)">🍗</span>
      <div>
        <div class="text-2xl font-bold leading-tight">Food Point POS</div>
        <div class="text-sm text-white/60">Multi-tenant point of sale for restaurants</div>
      </div>
      <a href="/admin/login" class="ml-auto text-sm bg-white/10 hover:bg-white/20 px-3 py-1.5 rounded-lg">Super admin</a>
    </div>

    <div class="mb-6">
      <h1 class="text-3xl md:text-4xl font-bold">Choose your restaurant</h1>
      <p class="text-white/60 mt-1">Each restaurant has its own data, branding, and users.</p>
    </div>

    <% if (!restaurants.length) { %>
      <div class="bg-white/5 border border-white/10 rounded-xl p-6 text-white/70">
        No restaurants are available yet. Ask your super admin to create one.
      </div>
    <% } else { %>
      <div class="grid gap-4 md:grid-cols-2 lg:grid-cols-3">
        <% restaurants.forEach(function(r){ %>
          <a href="/r/<%= r.slug %>/login" class="group bg-white/10 hover:bg-white/15 border border-white/10 rounded-2xl p-5 transition backdrop-blur">
            <div class="flex items-center gap-3">
              <% if (r.logoUrl) { %>
                <img src="<%= r.logoUrl %>" alt="<%= r.name %>" class="w-14 h-14 rounded-xl object-cover border border-white/20" />
              <% } else { %>
                <div class="w-14 h-14 rounded-xl flex items-center justify-center text-2xl text-white shadow"
                     style="background: linear-gradient(135deg, #22c55e, #0d9488)">🍗</div>
              <% } %>
              <div class="min-w-0">
                <div class="font-semibold truncate"><%= r.name %></div>
                <div class="text-xs text-white/60 truncate"><%= r.tagline || r.slug %></div>
              </div>
              <span class="ml-auto opacity-60 group-hover:opacity-100 transition">→</span>
            </div>
          </a>
        <% }); %>
      </div>
    <% } %>

    <div class="mt-10 text-center text-xs text-white/50">
      Want your restaurant listed? Ask your super admin to create it at <code>/admin/restaurants</code>.
    </div>
  </div>
</div>
