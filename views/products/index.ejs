<div class="flex items-center justify-between mb-4">
  <h1 class="text-2xl font-bold">Products</h1>
  <% if (currentUser && currentUser.role === 'admin') { %>
    <a href="/products/new" class="btn-primary">+ New Product</a>
  <% } %>
</div>

<form method="GET" class="card mb-4 flex flex-wrap gap-2 items-end">
  <div class="flex-1 min-w-[160px]">
    <label class="block text-xs text-gray-500">Search</label>
    <input name="q" value="<%= q %>" class="input" placeholder="Name or SKU..." />
  </div>
  <div>
    <label class="block text-xs text-gray-500">Category</label>
    <select name="category" class="input">
      <option value="">All</option>
      <% categories.forEach(function(c){ %>
        <option value="<%= c._id %>" <%= selectedCategory == String(c._id) ? 'selected' : '' %>><%= c.name %></option>
      <% }); %>
    </select>
  </div>
  <button class="btn-primary">Filter</button>
  <a href="/products" class="btn-secondary">Reset</a>
</form>

<div class="card">
  <% if (!products.length) { %>
    <div class="text-sm text-gray-500">No products match.</div>
  <% } else { %>
    <table class="table-base">
      <thead>
        <tr><th>Name</th><th>SKU</th><th>Category</th><th>Price</th><th>Status</th><th></th></tr>
      </thead>
      <tbody>
        <% products.forEach(function(p){ %>
          <tr>
            <td class="flex items-center gap-2">
              <% if (p.image) { %>
                <img src="<%= p.image %>" class="w-8 h-8 object-cover rounded" />
              <% } else { %>
                <span class="w-8 h-8 rounded bg-gray-200 inline-flex items-center justify-center">🍽️</span>
              <% } %>
              <span class="font-semibold"><%= p.name %></span>
            </td>
            <td class="font-mono text-gray-600"><%= p.sku || '—' %></td>
            <td><%= p.category ? p.category.name : '—' %></td>
            <td>Rs <%= p.price.toFixed(2) %></td>
            <td>
              <% if (p.active) { %>
                <span class="text-emerald-700 font-medium">Active</span>
              <% } else { %>
                <span class="text-gray-500">Inactive</span>
              <% } %>
            </td>
            <td>
              <% if (currentUser && currentUser.role === 'admin') { %>
                <a href="/products/<%= p._id %>/edit" class="text-brand-700 hover:underline">Edit</a>
                <form method="POST" action="/products/<%= p._id %>?_method=DELETE" class="inline" onsubmit="return confirm('Delete product?');">
                  <button class="text-red-700 hover:underline ml-2">Delete</button>
                </form>
              <% } %>
            </td>
          </tr>
        <% }); %>
      </tbody>
    </table>
  <% } %>
</div>
