<div class="max-w-2xl">
  <h1 class="text-2xl font-bold mb-4"><%= title %></h1>
  <form method="POST" action="<%= product._id ? '/products/' + product._id + '?_method=PUT' : '/products' %>"
        enctype="multipart/form-data" class="card grid gap-3 md:grid-cols-2">
    <div class="md:col-span-2">
      <label class="block text-sm font-medium mb-1">Name</label>
      <input name="name" class="input" value="<%= product.name || '' %>" required />
    </div>
    <div>
      <label class="block text-sm font-medium mb-1">SKU</label>
      <input name="sku" class="input" value="<%= product.sku || '' %>" />
    </div>
    <div>
      <label class="block text-sm font-medium mb-1">Category</label>
      <select name="category" class="input" required>
        <option value="">Select category</option>
        <% categories.forEach(function(c){ %>
          <option value="<%= c._id %>" <%= product.category && String(product.category) === String(c._id) ? 'selected' : '' %>><%= c.name %></option>
        <% }); %>
      </select>
    </div>
    <div>
      <label class="block text-sm font-medium mb-1">Price (Rs)</label>
      <input name="price" type="number" step="0.01" min="0" class="input" value="<%= product.price != null ? product.price : '' %>" required />
    </div>
    <div>
      <label class="block text-sm font-medium mb-1">Cost (Rs)</label>
      <input name="cost" type="number" step="0.01" min="0" class="input" value="<%= product.cost != null ? product.cost : '' %>" />
    </div>
    <div class="md:col-span-2">
      <label class="block text-sm font-medium mb-1">Description</label>
      <textarea name="description" class="input" rows="2"><%= product.description || '' %></textarea>
    </div>
    <div>
      <label class="block text-sm font-medium mb-1">Image</label>
      <input type="file" name="image" accept="image/*" />
      <% if (product.image) { %>
        <img src="<%= product.image %>" class="mt-2 w-20 h-20 object-cover rounded" />
      <% } %>
    </div>
    <label class="inline-flex items-center gap-2">
      <input type="checkbox" name="active" <%= (product._id === undefined || product.active) ? 'checked' : '' %> />
      <span>Active</span>
    </label>
    <div class="md:col-span-2 flex gap-2">
      <button class="btn-primary">Save</button>
      <a href="/products" class="btn-secondary">Cancel</a>
    </div>
  </form>
</div>
